  "keyFeatures": [
    "Multi-role user system (Admin, Trainer, Client)",
    "Custom diet plans and meal tracking",
    "Personalized workout routines and exercise library",
    "Trainer-client assignment and management",
    "Premium subscription system",
    "Progress tracking and calendar integration",
    "Blog for fitness articles and tips",
    "REST API built with Symfony and API Platform"
  ],
  "publicApiSurface": [
    "POST /api/login - User authentication",
    "POST /api/register - User registration",
    "GET /api/usuarios/me - Get current user profile",
    "GET /api/custom/dietas - Get user's diet plans",
    "GET /api/custom/entrenamientos - Get user's workouts",
    "GET /api/custom/ejercicios - Get exercise library",
    "POST /api/entrenador/crear-dieta - Create diet plan (trainer)",
    "POST /api/entrenador/crear-entrenamiento - Create workout (trainer)",
    "GET /api/entrenador/mis-clientes - Get trainer's clients",
    "GET /api/admin/usuarios - Manage users (admin)",
    "POST /api/blog - Create blog post",
    "GET /api/alimentos - Get food database"
  ]
